# ─── Telegram API (https://my.telegram.org/apps) ─────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token (https://t.me/BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# ─── Ruxsatlar ───────────────────────────────────────────────────────────────
OWNER_ID=123456789
ALLOWED_USERS=                  # vergul bilan ajratilgan ID lar (ixtiyoriy)
GROUP_ID=                       # majburiy emas, /pair orqali qo'shish tavsiya etiladi

# ─── HTTP API HMAC kaliti ────────────────────────────────────────────────────
# `python -c "import secrets; print(secrets.token_hex(32))"` orqali yarating
API_SECRET=replace_with_64_char_random_hex

# ─── Railway (avtomatik) ─────────────────────────────────────────────────────
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app
PORT=8080

# ─── Storage ─────────────────────────────────────────────────────────────────
# Bo'lmasa JSON fallback (~/.girgitton/state.json)
# REDIS_URL=redis://default:password@host:6379

# ─── Upload / Tezlik (Desktop App) ───────────────────────────────────────────
UPLOAD_WORKERS=5                  # 1..5 (Telegram bot session limiti)
UPLOAD_PARALLELISM=5              # bir batch ichida fayllar parallel
DELAY_BETWEEN_STEPS=0.3           # media album → document album orasi (s)
DELAY_BETWEEN_BATCHES=1.0         # batchlar orasi (s)
ROTATE_AFTER_N_BATCHES=15
ROTATE_AFTER_SECONDS=300
SPEED_DROP_THRESHOLD=0.5          # avg(3 batch) shu ostiga tushsa rotate
LAST_BATCH_SPEED_THRESHOLD=0.9    # oxirgi BITTA batch <0.9 MB/s -> darhol rotate
THROTTLE_SPEED_LIMIT=0.1          # bundan past = FloodWait simulyatsiyasi
THROTTLE_WAIT_SECONDS=1800

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true
