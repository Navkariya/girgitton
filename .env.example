# ── Telegram API ─────────────────────────────────────────────────────────────
# https://my.telegram.org/apps dan oling
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token — @BotFather dan oling
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# ── Ruxsatlar ─────────────────────────────────────────────────────────────────
# Siz uchun Telegram user ID (@userinfobot dan oling)
OWNER_ID=123456789

# Faqat shu guruhda ishlash (ixtiyoriy)
GROUP_ID=

# Qo'shimcha ruxsatli foydalanuvchilar (vergul bilan, ixtiyoriy)
ALLOWED_USERS=

# ── Mini API ──────────────────────────────────────────────────────────────────
# Desktop App autentifikatsiyasi uchun — istalgan uzun tasodifiy satr
API_SECRET=your_random_secret_here

# Railway tomonidan avtomatik qo'shiladi (o'zgartirishning hojati yo'q)
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway Redis addon tomonidan avtomatik qo'shiladi
# REDIS_URL=redis://...

# ── Worker Pool ───────────────────────────────────────────────────────────────
UPLOAD_WORKERS=3
ROTATE_AFTER_N_BATCHES=15
ROTATE_AFTER_SECONDS=300
SPEED_DROP_THRESHOLD=0.10
THROTTLE_SPEED_LIMIT=0.05
THROTTLE_WAIT_SECONDS=1800
