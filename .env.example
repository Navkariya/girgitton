# ─── Telegram API (https://my.telegram.org/apps) ─────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token (https://t.me/BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# ─── Ruxsatlar ───────────────────────────────────────────────────────────────
OWNER_ID=123456789
ALLOWED_USERS=                  # vergul bilan ajratilgan ID lar (ixtiyoriy)
GROUP_ID=                       # majburiy emas, /pair orqali qo'shish tavsiya etiladi

# ─── HTTP API HMAC kaliti ────────────────────────────────────────────────────
# `python -c "import secrets; print(secrets.token_hex(32))"` orqali yarating
API_SECRET=replace_with_64_char_random_hex

# ─── Railway (avtomatik) ─────────────────────────────────────────────────────
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app
PORT=8080

# ─── Storage ─────────────────────────────────────────────────────────────────
# Bo'lmasa JSON fallback (~/.girgitton/state.json)
# REDIS_URL=redis://default:password@host:6379

# ─── Upload (Desktop App) ────────────────────────────────────────────────────
UPLOAD_WORKERS=3
ROTATE_AFTER_N_BATCHES=15
ROTATE_AFTER_SECONDS=300
SPEED_DROP_THRESHOLD=0.10
THROTTLE_SPEED_LIMIT=0.05
THROTTLE_WAIT_SECONDS=1800

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true
